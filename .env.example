# Local dev:    cp .env.example .env.local   (next dev reads .env.local)
# Docker deploy: cp .env.example .env         (docker compose auto-loads .env)
#
# DEEPSEEK_* are server-only (no NEXT_PUBLIC_ prefix) → the key stays on the
# server; the browser only ever calls the app's own /api routes. If omitted or
# unreachable, the app falls back to the built-in offline poet.
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional: point the client at a different AI backend (defaults to same-origin /api).
# NEXT_PUBLIC_AI_ENDPOINT=/api

# Docker only: host port published by docker compose (container listens on 3000).
HOST_PORT=3210
