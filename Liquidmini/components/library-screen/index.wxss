:host { display: block; height: 100%; }
.lb { height: 100%; box-sizing: border-box; padding: 14px 16px; display: flex; flex-direction: column; gap: 12px; }

/* ── top half: selected spirit info ── */
.lb-detail { flex: 0 0 auto; max-height: 50%; min-height: 0; display: flex; gap: 14px; border-radius: 16px; padding: 14px; }
.lb-detail-bottle { width: 92px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
.lb-detail-info { flex: 1; min-width: 0; overflow-y: auto; }
.lb-detail-zh { display: block; font-family: var(--font-cinzel); font-size: 20px; letter-spacing: 0.05em; }
.lb-detail-en { display: block; font-family: var(--font-cormorant); font-style: italic; font-size: 13px; color: rgba(200,164,93,0.8); margin-top: 2px; }
.lb-detail-meta { display: flex; align-items: center; gap: 14px; margin-top: 8px; font-size: 12px; color: rgba(231,214,177,0.55); }
.lb-meta-item { display: flex; align-items: center; gap: 4px; }
.lb-detail-divider { height: 1px; background: rgba(200,164,93,0.2); margin: 10px 0; }
.lb-note { display: block; font-size: 13px; line-height: 1.6; color: rgba(231,214,177,0.75); }
.lb-flavor-label { display: block; font-size: 10px; text-transform: uppercase; letter-spacing: 0.2em; color: rgba(200,164,93,0.55); margin: 12px 0 8px; }
.lb-flavors { display: flex; flex-wrap: wrap; gap: 6px; }
.lb-flavor { border-radius: 999px; border: 1px solid rgba(200,164,93,0.25); color: rgba(231,214,177,0.8); font-size: 12px; padding: 4px 10px; }

/* ── page title (same style as Settings) ── */
.lb-head { display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; }
.lb-zh { font-family: var(--font-cinzel); font-size: 24px; letter-spacing: 0.06em; }
.lb-en { font-family: var(--font-cormorant); font-style: italic; font-size: 13px; color: rgba(200,164,93,0.7); }
.lb-count { margin-left: auto; font-size: 12px; color: rgba(231,214,177,0.45); }

/* ── bottom half: spirit picker ── */
.lb-pick { flex: 1; min-height: 0; display: flex; flex-direction: column; }

.lb-search { position: relative; display: flex; align-items: center; gap: 8px; margin-top: 10px; border-radius: 10px; border: 1px solid rgba(200,164,93,0.2); background: rgba(26,22,18,0.4); padding: 0 12px; }
.lb-input { flex: 1; padding: 9px 0; font-size: 14px; color: #E7D6B1; }
.lb-clear { padding: 4px; }

.lb-cats { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 10px; }
.lb-cat { border-radius: 999px; border: 1px solid rgba(200,164,93,0.15); color: rgba(231,214,177,0.65); font-size: 12px; padding: 5px 14px; }
.lb-cat.on { border-color: rgba(200,164,93,0.6); background: rgba(200,164,93,0.12); color: #E3C684; }

.lb-shelf-scroll { flex: 1; min-height: 0; margin-top: 10px; }
.lb-shelf { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; }
.lb-tile { display: flex; flex-direction: column; align-items: center; gap: 2px; padding: 6px 4px; border-radius: 10px; border: 1px solid rgba(200,164,93,0.15); text-align: center; }
.lb-tile.on { border-color: rgba(200,164,93,0.6); background: rgba(200,164,93,0.12); }
.lb-tile-art { width: 100%; height: 70px; display: flex; align-items: center; justify-content: center; }
.lb-tile-name { max-width: 100%; font-size: 11px; color: rgba(231,214,177,0.85); overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.lb-tile.on .lb-tile-name { color: #E3C684; }
.lb-tile-sub { max-width: 100%; font-size: 8px; text-transform: uppercase; letter-spacing: 0.06em; color: rgba(200,164,93,0.5); overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.lb-empty { grid-column: 1 / -1; text-align: center; padding: 32px 0; font-size: 14px; color: rgba(231,214,177,0.4); }
