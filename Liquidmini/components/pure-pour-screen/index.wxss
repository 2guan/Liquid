.pure {
  display: flex;
  flex-direction: column;
  height: 100%;
  padding: 10px 14px 14px;
  box-sizing: border-box;
}

/* step dots */
.steps { display: flex; justify-content: center; gap: 18px; flex-shrink: 0; margin-bottom: 8px; }
.step-dot { display: flex; flex-direction: column; align-items: center; gap: 3px; opacity: 0.5; }
.step-dot.on, .step-dot.done { opacity: 1; }
.step-num {
  width: 22px; height: 22px; line-height: 22px; text-align: center;
  border-radius: 50%; font-size: 12px;
  border: 1px solid rgba(200,164,93,0.4); color: rgba(231,214,177,0.8);
}
.step-dot.on .step-num { background: #C8A45D; color: #1A1612; border-color: #C8A45D; }
.step-dot.done .step-num { border-color: #C8A45D; color: #E3C684; }
.step-label { font-size: 10px; color: rgba(231,214,177,0.7); }

/* stage */
.stage {
  position: relative;
  flex-shrink: 0;
  height: 196px;
  margin-top: -4px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.pour-fx { position: absolute; left: 0; top: 0; right: 0; bottom: 0; z-index: 5; pointer-events: none; }
.stream { position: absolute; left: 50%; transform: translateX(-50%); top: 8%; width: 3px; height: 30%; border-radius: 4px; }
/* tilt the upright bottle via CSS (the SVG itself isn't rotated, so it never
   clips); pivot at the mouth so it reads as pouring into the glass below */
.pour-bottle { position: absolute; left: 50%; top: 4%; width: 80px; transform: translateX(-50%) rotate(128deg); transform-origin: 50% 9%; }

/* control panel */
.panel {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  border-radius: 14px;
  padding: 14px;
  margin-top: 6px;
}
.sel-head { display: flex; align-items: baseline; gap: 8px; }
.sel-zh { font-family: var(--font-cinzel); font-size: 17px; letter-spacing: 0.06em; color: #E3C684; }
.sel-en { font-family: var(--font-cormorant); font-style: italic; font-size: 12px; color: rgba(200,164,93,0.7); }
.sel-hint { display: block; font-size: 12px; color: rgba(231,214,177,0.5); margin: 4px 0 8px; line-height: 1.5; }

.search {
  width: 100%;
  min-height: 42px;
  border-radius: 10px;
  border: 1px solid rgba(200,164,93,0.2);
  background: rgba(26,22,18,0.4);
  padding: 11px 14px;
  font-size: 14px;
  line-height: 1.4;
  color: #E7D6B1;
  box-sizing: border-box;
}
.pills {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 8px;
}
.pill {
  border-radius: 999px;
  border: 1px solid rgba(200,164,93,0.15);
  color: rgba(231,214,177,0.65);
  font-size: 12px;
  padding: 5px 14px;
}
.pill.on { border-color: rgba(200,164,93,0.6); background: rgba(200,164,93,0.12); color: #E3C684; }

.grid-scroll { flex: 1; min-height: 0; margin-top: 8px; }
.grid { display: grid; gap: 6px; }
.grid-3 { grid-template-columns: repeat(3, 1fr); }
.grid-2 { grid-template-columns: repeat(2, 1fr); }
.grid.static { margin-top: 8px; }

.tile {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  padding: 6px 4px;
  border-radius: 10px;
  border: 1px solid rgba(200,164,93,0.15);
  text-align: center;
}
.tile.on { border-color: rgba(200,164,93,0.6); background: rgba(200,164,93,0.12); }
.tile-art { width: 100%; display: flex; align-items: center; justify-content: center; }
.tile-art.h64 { height: 64px; }
.tile-art.h84 { height: 84px; }
.tile-art.h72 { height: 72px; }
.tile-art.h56 { height: 56px; }
.tile-art.h52 { height: 52px; }
.ice-sw { width: 56px; height: 56px; }
.tile-label { font-size: 11px; color: rgba(231,214,177,0.85); }
.tile-sub { font-size: 8px; text-transform: uppercase; letter-spacing: 0.06em; color: rgba(200,164,93,0.5); }

/* pour */
.pour-body { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 16px; }
.gauge { position: relative; width: 100%; height: 12px; border-radius: 999px; background: #2A231B; overflow: hidden; }
.gauge-band { position: absolute; top: 0; bottom: 0; background: rgba(216,156,58,0.2); border-radius: 999px; }
.gauge-fill { height: 100%; border-radius: 999px; background: linear-gradient(90deg, #A9701F, #F0B14B); transition: width 0.1s linear; }
.pour-msg { font-size: 12px; color: rgba(231,214,177,0.55); }
.pour-btn {
  border-radius: 999px;
  background: linear-gradient(180deg, #D89C3A, #A9701F);
  color: #1A1612;
  padding: 14px 36px;
  font-size: 16px;
  box-shadow: 0 0 24px -6px rgba(216,156,58,0.7);
}
.pour-btn:active { background: linear-gradient(180deg, #E3C684, #C8A45D); }
.pour-reset { font-size: 12px; color: rgba(231,214,177,0.4); text-decoration: underline; }
.pour-reset.hidden { opacity: 0; pointer-events: none; }

/* footer */
.footer {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding-top: 12px;
  margin-top: 6px;
  border-top: 1px solid rgba(200,164,93,0.15);
}
.btn {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 10px 22px;
  border-radius: 999px;
  font-size: 14px;
  background: linear-gradient(180deg, #D89C3A, #A9701F);
  color: #1A1612;
}
.btn.ghost { background: transparent; border: 1px solid rgba(200,164,93,0.4); color: #E3C684; }
.btn.disabled { opacity: 0.4; pointer-events: none; }

/* loading veil (shown while the result is composing) */
.veil {
  position: fixed; left: 0; top: 0; right: 0; bottom: 0;
  z-index: 40;
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 18px;
  background: rgba(8,6,3,0.7);
}
.veil-mark { width: 64px; height: 64px; border-radius: 50%; box-shadow: 0 0 34px -8px rgba(240,177,75,0.55); animation: veilBreathe 3.2s ease-in-out infinite; }
@keyframes veilBreathe { 0%,100%{ opacity:.6; transform:scale(1) } 50%{ opacity:1; transform:scale(1.06) } }
.veil-dots { display: flex; gap: 6px; }
.veil-dots .d { width: 6px; height: 6px; border-radius: 50%; background: #C8A45D; animation: veilDot 1.1s ease-in-out infinite; }
.veil-dots .d:nth-child(2) { animation-delay: 0.18s; }
.veil-dots .d:nth-child(3) { animation-delay: 0.36s; }
@keyframes veilDot { 0%,100%{ opacity:.25 } 50%{ opacity:1 } }
.veil-line { font-size: 14px; letter-spacing: 0.05em; color: rgba(231,214,177,0.8); }
