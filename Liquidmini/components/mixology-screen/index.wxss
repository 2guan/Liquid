.mx { display: flex; flex-direction: column; height: 100%; padding: 10px 14px 14px; box-sizing: border-box; }

/* step dots */
.steps { display: flex; justify-content: center; gap: 24px; flex-shrink: 0; margin-bottom: 8px; }
.step-dot { display: flex; flex-direction: column; align-items: center; gap: 3px; opacity: 0.5; }
.step-dot.on, .step-dot.done { opacity: 1; }
.step-num { width: 22px; height: 22px; line-height: 22px; text-align: center; border-radius: 50%; font-size: 12px; border: 1px solid rgba(200,164,93,0.4); color: rgba(231,214,177,0.8); }
.step-dot.on .step-num { background: #C8A45D; color: #1A1612; border-color: #C8A45D; }
.step-dot.done .step-num { border-color: #C8A45D; color: #E3C684; }
.step-label { font-size: 10px; color: rgba(231,214,177,0.7); }

.mx-body { flex: 1; min-height: 0; }

.sel-zh { font-family: var(--font-cinzel); font-size: 17px; letter-spacing: 0.05em; color: #E3C684; }
.sel-zh.tcenter { display: block; text-align: center; }
.sel-hint { display: block; font-size: 12px; color: rgba(231,214,177,0.5); margin: 6px 0 8px; line-height: 1.6; }
.mx-divider { height: 1px; background: rgba(200,164,93,0.2); margin: 12px 0; }

/* search + cats */
.mx-search { position: relative; display: flex; align-items: center; gap: 8px; border-radius: 10px; border: 1px solid rgba(200,164,93,0.2); background: rgba(26,22,18,0.4); padding: 0 12px; }
.mx-input { flex: 1; padding: 10px 0; font-size: 14px; color: #E7D6B1; }
.mx-clear { padding: 4px; }
.mx-cats { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; }
.mx-cat { display: flex; align-items: center; gap: 6px; border-radius: 999px; border: 1px solid rgba(200,164,93,0.15); padding: 5px 12px; }
.mx-cat.on { border-color: rgba(200,164,93,0.6); background: rgba(200,164,93,0.12); }
.mx-cat-dot { width: 7px; height: 7px; border-radius: 50%; }
.mx-cat-zh { display: block; font-size: 12px; color: rgba(231,214,177,0.75); }
.mx-cat.on .mx-cat-zh { color: #E3C684; }
.mx-cat-en { display: block; font-size: 8px; text-transform: uppercase; letter-spacing: 0.06em; color: rgba(200,164,93,0.45); }

/* recipe cards */
.mx-recipes { display: flex; flex-direction: column; gap: 8px; }
.mx-card { display: flex; align-items: center; gap: 10px; border-radius: 12px; border: 1px solid rgba(200,164,93,0.2); padding: 9px 12px; }
.mx-card:active { border-color: rgba(200,164,93,0.5); }
.mx-card-glass { width: 64px; height: 80px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
.mx-card-info { flex: 1; min-width: 0; }
.mx-card-name { display: block; font-size: 17px; color: #E7D6B1; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.mx-card-en { display: block; font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; color: rgba(200,164,93,0.55); }
.mx-diff { display: flex; align-items: center; gap: 6px; margin-top: 6px; }
.mx-diff .dot { width: 6px; height: 6px; border-radius: 50%; background: rgba(231,214,177,0.2); }
.mx-diff .dot.on { background: #D89C3A; }
.mx-zero { margin-left: 4px; border-radius: 999px; border: 1px solid rgba(126,140,78,0.5); padding: 1px 8px; font-size: 9px; color: #7E8C4E; }
.mx-card-taste { display: block; margin-top: 5px; font-size: 12px; line-height: 1.45; color: rgba(231,214,177,0.45); }
.mx-empty { text-align: center; padding: 32px 0; font-size: 14px; color: rgba(231,214,177,0.4); }

/* ratio */
.mx-stage { height: 250px; display: flex; align-items: center; justify-content: center; }
.mx-panel { border-radius: 14px; padding: 16px; margin-top: 6px; }
.mx-panel-head { display: flex; align-items: center; justify-content: space-between; }
.mx-hint-toggle { font-size: 12px; color: rgba(200,164,93,0.75); text-decoration: underline; }
.mx-ings { display: flex; flex-direction: column; gap: 14px; }
.mx-ing-row { display: flex; align-items: baseline; justify-content: space-between; }
.mx-ing-name { font-size: 14px; color: rgba(231,214,177,0.9); }
.mx-ing-amt { font-size: 12px; color: rgba(231,214,177,0.45); }
.mx-target { color: rgba(200,164,93,0.75); }
.mx-slider { margin: 4px 2px 0; }
.mx-acc { margin-top: 16px; border-radius: 10px; border: 1px solid rgba(200,164,93,0.15); background: rgba(26,22,18,0.3); padding: 12px; }
.mx-acc-row { display: flex; align-items: center; justify-content: space-between; font-size: 12px; color: rgba(231,214,177,0.6); }
.mx-acc-pct { color: #E3C684; }
.mx-acc-bar { margin-top: 8px; height: 8px; border-radius: 999px; background: #2A231B; overflow: hidden; }
.mx-acc-fill { height: 100%; border-radius: 999px; background: linear-gradient(90deg, #A9701F, #E3C684); }

/* timing */
.mx-timing { display: flex; flex-direction: column; align-items: center; padding: 30px 16px; }
.mx-timing-lead { max-width: 520rpx; text-align: center; font-size: 13px; line-height: 1.7; color: rgba(231,214,177,0.55); margin-top: 8px; }
.mx-track { position: relative; width: 100%; height: 48px; margin-top: 30px; border-radius: 999px; border: 1px solid rgba(200,164,93,0.25); background: rgba(26,22,18,0.5); overflow: hidden; }
.mx-track-zone { position: absolute; top: 0; bottom: 0; left: 39%; width: 22%; border-radius: 8px; background: linear-gradient(90deg, rgba(216,156,58,0.3), rgba(200,164,93,0.4), rgba(216,156,58,0.3)); }
.mx-track-center { position: absolute; top: 0; bottom: 0; left: 50%; width: 2px; transform: translateX(-1px); background: rgba(227,198,132,0.6); }
.mx-track-marker { position: absolute; top: 50%; transform: translateY(-50%); width: 6px; height: 36px; border-radius: 999px; background: #E3C684; box-shadow: 0 0 14px -2px rgba(240,177,75,0.8); }
.mx-lock { margin-top: 30px; }
.mx-timing-msg { font-size: 18px; color: #E3C684; margin-top: 28px; }
.mx-timing-score { font-size: 14px; color: rgba(231,214,177,0.5); margin-top: 4px; }
.mx-finish { margin-top: 20px; }

/* footer + buttons */
.footer { flex-shrink: 0; display: flex; align-items: center; justify-content: space-between; gap: 12px; padding-top: 12px; margin-top: 6px; border-top: 1px solid rgba(200,164,93,0.15); }
.btn { display: flex; align-items: center; justify-content: center; gap: 6px; padding: 11px 24px; border-radius: 999px; font-size: 14px; background: linear-gradient(180deg, #D89C3A, #A9701F); color: #1A1612; }
.btn.ghost { background: transparent; border: 1px solid rgba(200,164,93,0.4); color: #E3C684; }
.btn.disabled { opacity: 0.4; }

/* veil */
.veil { position: fixed; left: 0; top: 0; right: 0; bottom: 0; z-index: 40; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 18px; background: rgba(8,6,3,0.7); }
.veil-mark { width: 64px; height: 64px; border-radius: 50%; box-shadow: 0 0 34px -8px rgba(240,177,75,0.55); animation: veilBreathe 3.2s ease-in-out infinite; }
@keyframes veilBreathe { 0%,100%{ opacity:.6; transform:scale(1) } 50%{ opacity:1; transform:scale(1.06) } }
.veil-dots { display: flex; gap: 6px; }
.veil-dots .d { width: 6px; height: 6px; border-radius: 50%; background: #C8A45D; animation: veilDot 1.1s ease-in-out infinite; }
.veil-dots .d:nth-child(2) { animation-delay: 0.18s; }
.veil-dots .d:nth-child(3) { animation-delay: 0.36s; }
@keyframes veilDot { 0%,100%{ opacity:.25 } 50%{ opacity:1 } }
.veil-line { font-size: 14px; color: rgba(231,214,177,0.8); }
