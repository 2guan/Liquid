<scroll-view scroll-y class="set-scroll">
  <view class="set">
    <view class="set-head">
      <text class="set-zh title-engrave">设置</text>
      <text class="set-en">Settings</text>
    </view>

    <!-- 音效 -->
    <text class="section-label">音效 · Sound</text>
    <view class="setting" bindtap="toggleMusic">
      <view class="setting-left">
        <icon name="{{musicOn ? 'sound-on' : 'sound-off'}}" size="20" color="#C8A45D"></icon>
        <view>
          <text class="setting-name">背景音乐</text>
          <text class="setting-sub">吧台爵士氛围乐</text>
        </view>
      </view>
      <view class="toggle {{musicOn ? 'on' : ''}}"><view class="knob"></view></view>
    </view>
    <view class="setting" bindtap="toggleSfx">
      <view class="setting-left">
        <icon name="{{sfxOn ? 'sound-on' : 'sound-off'}}" size="20" color="#C8A45D"></icon>
        <view>
          <text class="setting-name">按钮音效</text>
          <text class="setting-sub">点击、倒酒、加冰等交互音</text>
        </view>
      </view>
      <view class="toggle {{sfxOn ? 'on' : ''}}"><view class="knob"></view></view>
    </view>

    <!-- 关于 -->
    <text class="section-label">关于 · About</text>
    <view class="about">
      <text class="about-zh title-engrave">微醺时刻</text>
      <text class="about-en">The Sip & Sigh</text>
      <text class="about-body">夜色温柔，城市次第熄灯。这里没有喧嚣，只有一盏暖光、一段心事，和一杯为你而调的酒。说出此刻的心绪，光影便为你斟满杯盏，把悲欢酿成色泽与气味——或浓烈，或清浅，或层层流转。愿每一次微醺，都是与自己温柔相认的时刻。</text>
      <text class="about-ver">v1.04</text>
    </view>
  </view>
</scroll-view>
