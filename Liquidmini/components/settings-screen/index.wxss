.set-scroll { height: 100%; }
.set { padding: 16px 16px 32px; box-sizing: border-box; }

.set-head { display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; margin-bottom: 14px; }
.set-zh { font-family: var(--font-cinzel); font-size: 24px; letter-spacing: 0.06em; }
.set-en { font-family: var(--font-cormorant); font-style: italic; font-size: 13px; color: rgba(200,164,93,0.7); }

.section-label { display: block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.2em; color: rgba(200,164,93,0.55); margin: 6px 0 12px; }
.section-label:not(:first-of-type) { margin-top: 24px; }

.setting { display: flex; align-items: center; justify-content: space-between; border-radius: 14px; border: 1px solid rgba(200,164,93,0.15); background: rgba(21,17,13,0.5); padding: 16px; margin-bottom: 10px; }
.setting-left { display: flex; align-items: center; gap: 12px; }
.setting-name { display: block; font-size: 14px; color: #E7D6B1; }
.setting-sub { display: block; font-size: 11px; color: rgba(231,214,177,0.45); }
.toggle { width: 46px; height: 26px; border-radius: 999px; background: rgba(200,164,93,0.2); padding: 3px; box-sizing: border-box; transition: background 0.2s; }
.toggle.on { background: rgba(216,156,58,0.6); }
.knob { width: 20px; height: 20px; border-radius: 50%; background: #E7D6B1; transition: transform 0.2s; }
.toggle.on .knob { transform: translateX(20px); }

.about { border-radius: 14px; border: 1px solid rgba(200,164,93,0.15); background: rgba(21,17,13,0.5); padding: 18px; }
.about-zh { display: block; font-family: var(--font-cinzel); font-size: 20px; letter-spacing: 0.04em; }
.about-en { display: block; font-family: var(--font-cormorant); font-style: italic; font-size: 14px; color: rgba(200,164,93,0.75); margin-top: 2px; }
.about-body { display: block; font-size: 13px; line-height: 1.7; color: rgba(231,214,177,0.6); margin-top: 12px; }
.about-ver { display: block; font-size: 11px; color: rgba(231,214,177,0.35); margin-top: 12px; }
