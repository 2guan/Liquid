.ach-scroll { height: 100%; }
.ach { padding: 16px 14px 32px; box-sizing: border-box; }

.ach-head { display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; margin-bottom: 14px; }
.ach-zh { font-family: var(--font-cinzel); font-size: 24px; letter-spacing: 0.06em; }
.ach-en { font-family: var(--font-cormorant); font-style: italic; font-size: 13px; color: rgba(200,164,93,0.7); }

.rank-card { border-radius: 18px; padding: 18px; }
.rank-top { display: flex; align-items: center; justify-content: space-between; }
.rank-name { display: block; font-size: 20px; color: #E7D6B1; }
.rank-nameen { display: block; font-size: 10px; text-transform: uppercase; letter-spacing: 0.2em; color: rgba(200,164,93,0.6); }
.rank-bar { height: 10px; border-radius: 999px; background: #2A231B; overflow: hidden; margin-top: 14px; }
.rank-fill { height: 100%; border-radius: 999px; background: linear-gradient(90deg, #A9701F, #D89C3A, #E3C684); }
.rank-meta { display: flex; justify-content: space-between; font-size: 11px; color: rgba(231,214,177,0.45); margin-top: 8px; }
/* rank timeline: current + next two milestones */
.timeline { display: flex; align-items: flex-start; margin-top: 18px; }
.tl-node { display: flex; flex-direction: column; align-items: center; gap: 5px; width: 84px; flex-shrink: 0; }
.tl-dot { width: 14px; height: 14px; box-sizing: border-box; border-radius: 50%; border: 2px solid rgba(200,164,93,0.4); background: #15110d; }
.tl-node.done .tl-dot { background: rgba(200,164,93,0.55); border-color: rgba(200,164,93,0.55); }
.tl-node.cur .tl-dot { background: #E3C684; border-color: #E3C684; box-shadow: 0 0 10px -2px #E3C684; }
.tl-name { font-size: 12px; line-height: 1.2; text-align: center; color: rgba(231,214,177,0.45); }
.tl-node.done .tl-name { color: rgba(231,214,177,0.7); }
.tl-node.cur .tl-name { color: #E3C684; }
.tl-xp { font-size: 9px; color: rgba(231,214,177,0.35); }
.tl-conn { flex: 1; height: 3px; border-radius: 999px; background: rgba(200,164,93,0.15); margin-top: 7px; position: relative; overflow: hidden; }
.tl-conn-fill { position: absolute; left: 0; top: 0; bottom: 0; border-radius: 999px; background: linear-gradient(90deg, #D89C3A, #E3C684); }

.stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-top: 18px; }
.stat { display: flex; flex-direction: column; align-items: center; gap: 6px; border-radius: 14px; border: 1px solid rgba(200,164,93,0.15); background: rgba(21,17,13,0.5); padding: 16px 8px; }
.stat-val { font-size: 24px; color: #E7D6B1; }
.stat-label { font-size: 11px; color: rgba(231,214,177,0.5); }

.section-row { display: flex; align-items: baseline; justify-content: space-between; margin: 26px 2px 12px; }
.section-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.2em; color: rgba(200,164,93,0.55); }
.section-count { font-size: 12px; color: rgba(231,214,177,0.45); }

.group { margin-bottom: 22px; }
.group-head { display: flex; align-items: center; gap: 7px; margin-bottom: 10px; }
.group-icn { width: 24px; height: 24px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; border-radius: 50%; border: 1px solid rgba(200,164,93,0.3); }
.group-name { font-size: 14px; color: rgba(231,214,177,0.9); }
.group-en { font-size: 11px; font-style: italic; color: rgba(200,164,93,0.45); }
.group-got { margin-left: auto; font-size: 10px; color: rgba(231,214,177,0.35); }

/* 3 per row */
.badges { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
.badge {
  display: flex; flex-direction: column; align-items: center; text-align: center;
  border-radius: 12px; border: 1px solid rgba(200,164,93,0.12);
  background: rgba(21,17,13,0.4);
  padding: 10px 6px;
  opacity: 0.82;
}
.badge.done { background: rgba(200,164,93,0.07); opacity: 1; }
.badge-icn { width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; border-radius: 50%; border: 1px solid rgba(200,164,93,0.2); }
.badge-name { font-size: 11px; line-height: 1.25; color: #E7D6B1; margin-top: 6px; }
.badge-name.dim { color: rgba(231,214,177,0.55); }
.badge-xp { font-size: 8px; text-transform: uppercase; letter-spacing: 0.06em; color: rgba(200,164,93,0.5); margin-top: 2px; }
.badge-done { font-size: 9px; color: #E3C684; margin-top: 4px; }
.badge-bar { width: 100%; height: 4px; border-radius: 999px; background: #2A231B; overflow: hidden; margin-top: 6px; }
.badge-fill { height: 100%; border-radius: 999px; background: rgba(200,164,93,0.6); }
.badge-prog { font-size: 8px; color: rgba(231,214,177,0.4); margin-top: 3px; }
