.ach-scroll { height: 100%; }
.ach { padding: 16px 16px 32px; box-sizing: border-box; }

.ach-head { display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; margin-bottom: 14px; }
.ach-zh { font-family: var(--font-cinzel); font-size: 24px; letter-spacing: 0.06em; }
.ach-en { font-family: var(--font-cormorant); font-style: italic; font-size: 13px; color: rgba(200,164,93,0.7); }

.rank-card { border-radius: 18px; padding: 18px; }
.rank-top { display: flex; align-items: center; justify-content: space-between; }
.rank-name { display: block; font-size: 20px; color: #E7D6B1; }
.rank-nameen { display: block; font-size: 10px; text-transform: uppercase; letter-spacing: 0.2em; color: rgba(200,164,93,0.6); }
.rank-bar { height: 10px; border-radius: 999px; background: #2A231B; overflow: hidden; margin-top: 14px; }
.rank-fill { height: 100%; border-radius: 999px; background: linear-gradient(90deg, #A9701F, #D89C3A, #E3C684); }
.rank-meta { display: flex; justify-content: space-between; font-size: 11px; color: rgba(231,214,177,0.45); margin-top: 8px; }
.ladder { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-top: 18px; }
.ladder-cell { border-radius: 10px; border: 1px solid rgba(200,164,93,0.12); padding: 8px 4px; text-align: center; }
.ladder-cell.on { border-color: rgba(200,164,93,0.45); background: rgba(200,164,93,0.1); }
.ladder-name { display: block; font-size: 11px; color: rgba(231,214,177,0.4); }
.ladder-cell.on .ladder-name { color: #E3C684; }
.ladder-xp { display: block; font-size: 9px; color: rgba(231,214,177,0.35); }

.stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-top: 18px; }
.stat { display: flex; flex-direction: column; align-items: center; gap: 6px; border-radius: 14px; border: 1px solid rgba(200,164,93,0.15); background: rgba(21,17,13,0.5); padding: 16px 8px; }
.stat-val { font-size: 26px; color: #E7D6B1; }
.stat-label { font-size: 11px; color: rgba(231,214,177,0.5); }

.section-label { display: block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.2em; color: rgba(200,164,93,0.55); margin: 24px 0 12px; }

.badges { display: flex; flex-direction: column; gap: 10px; }
.badge { display: flex; align-items: center; gap: 12px; border-radius: 14px; border: 1px solid rgba(200,164,93,0.12); padding: 14px; opacity: 0.6; }
.badge.got { border-color: rgba(200,164,93,0.4); background: rgba(200,164,93,0.08); opacity: 1; }
.badge-icn { width: 44px; height: 44px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; border-radius: 50%; border: 1px solid rgba(200,164,93,0.2); }
.badge.got .badge-icn { border-color: rgba(200,164,93,0.5); }
.badge-name { display: block; font-size: 14px; color: rgba(231,214,177,0.6); }
.badge.got .badge-name { color: #E7D6B1; }
.badge-en { display: block; font-size: 8px; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(200,164,93,0.5); }
.badge-hint { display: block; font-size: 11px; color: rgba(231,214,177,0.45); margin-top: 2px; }

.setting { display: flex; align-items: center; justify-content: space-between; border-radius: 14px; border: 1px solid rgba(200,164,93,0.15); background: rgba(21,17,13,0.5); padding: 16px; }
.setting-left { display: flex; align-items: center; gap: 12px; }
.setting-name { display: block; font-size: 14px; color: #E7D6B1; }
.setting-sub { display: block; font-size: 11px; color: rgba(231,214,177,0.45); }
.toggle { width: 46px; height: 26px; border-radius: 999px; background: rgba(200,164,93,0.2); padding: 3px; box-sizing: border-box; transition: background 0.2s; }
.toggle.on { background: rgba(216,156,58,0.6); }
.knob { width: 20px; height: 20px; border-radius: 50%; background: #E7D6B1; transition: transform 0.2s; }
.toggle.on .knob { transform: translateX(20px); }
