<scroll-view scroll-y class="ach-scroll">
  <view class="ach">
    <view class="ach-head">
      <text class="ach-zh title-engrave">成就 · 工坊档案</text>
      <text class="ach-en">Achievements</text>
    </view>

    <!-- rank progress -->
    <view class="glass-panel rank-card">
      <view class="rank-top">
        <view>
          <text class="rank-name">{{rankName}}</text>
          <text class="rank-nameen">{{rankNameEn}}</text>
        </view>
        <icon name="trophy" size="30" color="#C8A45D"></icon>
      </view>
      <view class="rank-bar"><view class="rank-fill" style="width:{{progressPct}}%"></view></view>
      <view class="rank-meta">
        <text>{{xp}} XP</text>
        <text>{{nextText}}</text>
      </view>
      <view class="ladder">
        <view wx:for="{{ranks}}" wx:key="id" class="ladder-cell {{item.current ? 'cur' : ''}} {{item.reached ? 'on' : ''}}">
          <text class="ladder-name">{{item.name}}</text>
          <text class="ladder-xp">{{item.xp}}</text>
        </view>
      </view>
    </view>

    <!-- stats -->
    <view class="stats">
      <view wx:for="{{stats}}" wx:key="label" class="stat">
        <icon name="{{item.icon}}" size="22" color="#C8A45D"></icon>
        <text class="stat-val">{{item.value}}</text>
        <text class="stat-label">{{item.label}}</text>
      </view>
    </view>

    <!-- badges -->
    <view class="section-row">
      <text class="section-label">徽章 · Badges</text>
      <text class="section-count">{{doneCount}} / {{total}}</text>
    </view>

    <view wx:for="{{groups}}" wx:key="id" class="group">
      <view class="group-head">
        <view class="group-icn"><icon name="{{item.icon}}" size="13" color="#C8A45D"></icon></view>
        <text class="group-name">{{item.name}}</text>
        <text class="group-en">{{item.nameEn}}</text>
        <text class="group-got">{{item.got}}/{{item.total}}</text>
      </view>
      <view class="badges">
        <view wx:for="{{item.items}}" wx:for-item="bdg" wx:key="id" class="badge {{bdg.done ? 'done' : ''}}" style="{{bdg.done ? 'border-color:' + bdg.color + '99;' : ''}}">
          <view class="badge-icn" style="border-color:{{bdg.done ? bdg.color : 'rgba(200,164,93,0.2)'}}">
            <icon name="{{bdg.icon}}" size="16" color="{{bdg.color}}"></icon>
          </view>
          <text class="badge-name {{bdg.done ? '' : 'dim'}}">{{bdg.name}}</text>
          <text class="badge-xp">+{{bdg.xp}} XP</text>
          <block wx:if="{{bdg.done}}">
            <text class="badge-done">✓ 已解锁</text>
          </block>
          <block wx:else>
            <view class="badge-bar"><view class="badge-fill" style="width:{{bdg.pct}}%"></view></view>
            <text class="badge-prog">{{bdg.cur}}/{{bdg.goal}}</text>
          </block>
        </view>
      </view>
    </view>
  </view>
</scroll-view>
