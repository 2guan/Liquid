.pure { display: flex; flex-direction: column; height: 100%; padding: 10px 14px 14px; box-sizing: border-box; }

/* stage (resizable: hidden / normal / large) */
.stage { position: relative; flex-shrink: 0; height: 196px; margin-top: -4px; display: flex; align-items: center; justify-content: center; overflow: hidden; transition: height 0.25s ease, opacity 0.2s ease, margin 0.25s ease; }
/* resize only on the build step — glass/ice steps stay at the normal height.
   Concrete heights (px / calc) so the change animates via the stage transition. */
.pure.hidden.step-build .stage { height: 0; opacity: 0; margin-top: 0; }
/* large: the glass stage fills the space down to the title block; the panel
   shrinks to just its header (title + divider) with no empty gap below it */
.pure.large.step-build .stage { height: calc(100% - 188px); }
.pure.large.step-build .panel { flex: 0 0 auto; }
.pure.large.step-build .build-picker { display: none; }

/* the build picker (everything under the first divider) */
.build-picker { flex: 1; min-height: 0; display: flex; flex-direction: column; }
.sep { height: 1px; margin: 8px 0; background: linear-gradient(90deg, transparent, rgba(200,164,93,0.28), transparent); }

/* drag handle to collapse the stage */
.sheet-handle { display: flex; flex-direction: column; align-items: center; gap: 4px; padding: 2px 0 8px; }
.grip { width: 38px; height: 4px; border-radius: 999px; background: rgba(200,164,93,0.4); }
.handle-hint { font-size: 10px; color: rgba(231,214,177,0.4); letter-spacing: 0.04em; }
.layer-badge {
  position: absolute; left: 16px; top: 50%; transform: translateY(-50%); z-index: 5;
  border-radius: 999px; border: 1px solid rgba(200,164,93,0.3);
  background: rgba(26,22,18,0.6); color: rgba(200,164,93,0.8);
  font-size: 10px; padding: 3px 9px;
}

/* control panel */
.panel { flex: 1; min-height: 0; display: flex; flex-direction: column; border-radius: 14px; padding: 14px; margin-top: 6px; }
.sel-head { display: flex; align-items: baseline; gap: 8px; }
.sel-zh { font-family: var(--font-cinzel); font-size: 17px; letter-spacing: 0.06em; color: #E3C684; }
.sel-en { font-family: var(--font-cormorant); font-style: italic; font-size: 12px; color: rgba(200,164,93,0.7); }
.sel-hint { display: block; font-size: 12px; color: rgba(231,214,177,0.5); margin: 4px 0 8px; line-height: 1.5; }

.search { width: 100%; min-height: 40px; border-radius: 10px; border: 1px solid rgba(200,164,93,0.2); background: rgba(26,22,18,0.4); padding: 9px 14px; font-size: 13px; line-height: 1.4; color: #E7D6B1; box-sizing: border-box; }
.pills { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 8px; }
.pill { border-radius: 999px; border: 1px solid rgba(0,0,0,0.4); color: rgba(231,214,177,0.65); font-size: 11px; line-height: 1.3; padding: 3px 9px; }
.pill.on { border-color: rgba(200,164,93,0.6); background: rgba(200,164,93,0.12); color: #E3C684; }

.grid-scroll { flex: 1; min-height: 0; margin-top: 8px; }
.grid { display: grid; gap: 6px; }
.grid-3 { grid-template-columns: repeat(3, 1fr); }
.grid-2 { grid-template-columns: repeat(2, 1fr); }
.grid.static { margin-top: 8px; }

.tile { display: flex; flex-direction: column; align-items: center; gap: 2px; padding: 6px 4px; border-radius: 10px; border: 1px solid rgba(0,0,0,0.4); text-align: center; }
.tile.on { border-color: rgba(200,164,93,0.6); background: rgba(200,164,93,0.12); }
.tile-art { width: 100%; display: flex; align-items: center; justify-content: center; }
.tile-art.h56 { height: 56px; }
.tile-art.h52 { height: 52px; }
.ice-sw { width: 56px; height: 56px; }
.tile-label { font-size: 11px; color: rgba(231,214,177,0.85); }
.tile-sub { font-size: 8px; text-transform: uppercase; letter-spacing: 0.06em; color: rgba(200,164,93,0.5); }

/* added ingredient list (build step) */
.added { max-height: 150px; margin-bottom: 8px; }
.brow { display: flex; align-items: center; gap: 6px; padding: 5px 6px; margin-bottom: 5px; border-radius: 9px; border: 1px solid rgba(200,164,93,0.15); background: rgba(26,22,18,0.3); }
.bn { width: 18px; height: 18px; line-height: 18px; text-align: center; flex-shrink: 0; border-radius: 50%; border: 1px solid rgba(200,164,93,0.3); font-size: 9px; color: rgba(200,164,93,0.8); }
.bdot { width: 14px; height: 14px; flex-shrink: 0; border-radius: 50%; border: 1px solid rgba(231,214,177,0.2); }
.bname { flex: 1; min-width: 0; font-size: 12px; color: rgba(231,214,177,0.85); overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.btag { color: rgba(231,214,177,0.35); margin-left: 3px; }
.bstep { display: flex; align-items: center; gap: 2px; flex-shrink: 0; }
.bbtn { width: 20px; height: 20px; line-height: 18px; text-align: center; border-radius: 5px; border: 1px solid rgba(200,164,93,0.25); color: rgba(231,214,177,0.75); font-size: 14px; }
.bamt { width: 46px; text-align: center; font-size: 11px; color: #E3C684; }
.bmv { width: 16px; text-align: center; flex-shrink: 0; font-size: 13px; color: rgba(231,214,177,0.55); }
.bmv.off { opacity: 0.25; pointer-events: none; }
.bx { width: 18px; text-align: center; flex-shrink: 0; font-size: 12px; color: rgba(231,214,177,0.45); }

.empty-hint { padding: 12px 0; text-align: center; font-size: 12px; color: rgba(231,214,177,0.4); border: 1px dashed rgba(200,164,93,0.2); border-radius: 9px; margin-bottom: 8px; }

/* stir + undo */
.actions { display: flex; gap: 8px; margin-bottom: 8px; }
.act { flex: 1; display: flex; align-items: center; justify-content: center; gap: 5px; padding: 8px 0; border-radius: 9px; border: 1px solid rgba(200,164,93,0.2); color: rgba(231,214,177,0.75); font-size: 12px; }
.act.on { border-color: rgba(200,164,93,0.55); background: rgba(200,164,93,0.12); color: #E3C684; }
.act.off { opacity: 0.35; pointer-events: none; }

/* ingredient picker list — two compact tiles per row */
.ilist { display: grid; grid-template-columns: repeat(2, 1fr); gap: 6px; }
.irow { display: flex; align-items: center; gap: 6px; padding: 6px; border-radius: 9px; border: 1px solid rgba(0,0,0,0.4); overflow: hidden; }
.irow.off { opacity: 0.3; pointer-events: none; }
.irow.on { border-color: rgba(200,164,93,0.55); background: rgba(200,164,93,0.1); }
.idot { width: 20px; height: 20px; flex-shrink: 0; border-radius: 50%; border: 1px solid rgba(231,214,177,0.2); }
.imeta { flex: 1 1 0; min-width: 0; display: flex; flex-direction: column; overflow: hidden; }
.iname { display: block; max-width: 100%; font-size: 12px; color: rgba(231,214,177,0.9); overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.irow.on .iname { color: #E3C684; }
.isub { display: block; max-width: 100%; font-size: 9px; font-style: italic; color: rgba(200,164,93,0.55); overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.iplus { flex-shrink: 0; width: 16px; height: 16px; display: flex; align-items: center; justify-content: center; }

/* footer */
.footer { flex-shrink: 0; display: flex; align-items: center; justify-content: space-between; gap: 12px; padding-top: 12px; margin-top: 6px; border-top: 1px solid rgba(200,164,93,0.15); }
.btn { display: flex; align-items: center; gap: 6px; padding: 10px 22px; border-radius: 999px; font-size: 14px; background: linear-gradient(180deg, #D89C3A, #A9701F); color: #1A1612; }
.btn.ghost { background: transparent; border: 1px solid rgba(200,164,93,0.4); color: #E3C684; }
.btn.disabled { opacity: 0.4; pointer-events: none; }

/* loading veil */
.veil { position: fixed; left: 0; top: 0; right: 0; bottom: 0; z-index: 40; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 18px; background: rgba(8,6,3,0.7); }
.veil-mark { width: 64px; height: 64px; border-radius: 50%; box-shadow: 0 0 34px -8px rgba(240,177,75,0.55); animation: veilBreathe 3.2s ease-in-out infinite; }
@keyframes veilBreathe { 0%,100%{ opacity:.6; transform:scale(1) } 50%{ opacity:1; transform:scale(1.06) } }
.veil-dots { display: flex; gap: 6px; }
.veil-dots .d { width: 6px; height: 6px; border-radius: 50%; background: #C8A45D; animation: veilDot 1.1s ease-in-out infinite; }
.veil-dots .d:nth-child(2) { animation-delay: 0.18s; }
.veil-dots .d:nth-child(3) { animation-delay: 0.36s; }
@keyframes veilDot { 0%,100%{ opacity:.25 } 50%{ opacity:1 } }
.veil-line { font-size: 14px; letter-spacing: 0.05em; color: rgba(231,214,177,0.8); }
