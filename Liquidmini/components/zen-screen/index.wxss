.zen { display: flex; flex-direction: column; height: 100%; padding: 12px 14px 14px; box-sizing: border-box; gap: 12px; }

.sel-zh { font-family: var(--font-cinzel); font-size: 16px; letter-spacing: 0.05em; color: #E3C684; }

/* canvas */
.zen-canvas { position: relative; height: 300px; flex-shrink: 0; border-radius: 18px; border: 1px solid rgba(200,164,93,0.2); overflow: hidden; }
.zen-scene { position: absolute; left: 0; top: 0; width: 100%; height: 100%; opacity: 0.5; }
.zen-edges { position: absolute; left: 0; top: 0; width: 100%; height: 100%; }
.zen-cap { position: absolute; left: 14px; top: 12px; z-index: 2; }
.zen-cap-sub { display: block; font-size: 11px; color: rgba(231,214,177,0.55); margin-top: 4px; }

.zen-cauldron { position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); display: flex; flex-direction: column; align-items: center; z-index: 1; }
.zen-pot { width: 72px; height: 72px; display: flex; align-items: center; justify-content: center; border-radius: 50%; border: 1px solid rgba(200,164,93,0.4); background: rgba(26,22,18,0.6); box-shadow: 0 0 24px -6px rgba(216,156,58,0.5); }
.zen-pot-label { font-size: 10px; color: rgba(200,164,93,0.6); margin-top: 4px; }

.zen-orb { position: absolute; transform: translate(-50%, -50%); z-index: 3; display: flex; flex-direction: column; align-items: center; }
.zen-orb-ring { position: absolute; top: 0; width: 48px; height: 48px; border-radius: 50%; border: 1px solid; opacity: 0.4; }
.zen-orb-body { width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; border-radius: 50%; border: 1px solid rgba(231,214,177,0.3); }
.zen-orb-short { font-size: 11px; color: rgba(26,22,18,0.85); }
.zen-orb-name { max-width: 84px; font-size: 10px; color: rgba(231,214,177,0.85); margin-top: 4px; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.zen-orb-x { position: absolute; right: -6px; top: -6px; width: 20px; height: 20px; display: flex; align-items: center; justify-content: center; border-radius: 50%; border: 1px solid rgba(200,164,93,0.4); background: #0E0B08; }

.zen-empty { position: absolute; left: 0; right: 0; bottom: 14px; text-align: center; font-size: 13px; color: rgba(231,214,177,0.4); }

/* panel */
.zen-panel { flex: 1; min-height: 0; display: flex; flex-direction: column; border-radius: 16px; padding: 14px; }
.zen-panel-head { display: flex; align-items: baseline; justify-content: space-between; }
.zen-counter { font-size: 11px; color: rgba(231,214,177,0.45); }

.zen-search { position: relative; display: flex; align-items: center; gap: 8px; margin-top: 10px; border-radius: 10px; border: 1px solid rgba(200,164,93,0.2); background: rgba(26,22,18,0.4); padding: 0 12px; }
.zen-input { flex: 1; padding: 9px 0; font-size: 14px; color: #E7D6B1; }
.zen-clear { padding: 4px; }

.zen-cats { white-space: nowrap; margin-top: 10px; }
.zen-cat { display: inline-flex; align-items: center; gap: 6px; border-radius: 999px; border: 1px solid rgba(200,164,93,0.15); color: rgba(231,214,177,0.65); font-size: 12px; padding: 5px 12px; margin-right: 6px; }
.zen-cat.on { border-color: rgba(200,164,93,0.6); background: rgba(200,164,93,0.12); color: #E3C684; }
.zen-cat-dot { width: 8px; height: 8px; border-radius: 50%; }

.zen-divider { height: 1px; background: rgba(200,164,93,0.2); margin: 12px 0; }

.zen-list { flex: 1; min-height: 0; }
.zen-item { display: flex; align-items: center; gap: 10px; border-radius: 10px; border: 1px solid rgba(200,164,93,0.12); padding: 9px 10px; margin-bottom: 6px; }
.zen-item.on { border-color: rgba(200,164,93,0.55); background: rgba(200,164,93,0.12); }
.zen-item.disabled { opacity: 0.3; }
.zen-item-dot { width: 28px; height: 28px; flex-shrink: 0; border-radius: 50%; border: 1px solid rgba(231,214,177,0.2); }
.zen-item-text { flex: 1; min-width: 0; }
.zen-item-name { display: block; font-size: 13px; color: rgba(231,214,177,0.9); overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.zen-item-sub { display: block; font-family: var(--font-cormorant); font-style: italic; font-size: 10px; color: rgba(200,164,93,0.55); overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.zen-empty-list { text-align: center; padding: 24px 0; font-size: 14px; color: rgba(231,214,177,0.4); }

.btn { display: flex; align-items: center; justify-content: center; gap: 8px; padding: 12px 24px; border-radius: 999px; font-size: 15px; background: linear-gradient(180deg, #D89C3A, #A9701F); color: #1A1612; }
.zen-analyze { margin-top: 12px; }
.btn.disabled { opacity: 0.4; }
.zen-hint { text-align: center; font-size: 10px; color: rgba(231,214,177,0.4); margin-top: 8px; }

/* veil */
.veil { position: fixed; left: 0; top: 0; right: 0; bottom: 0; z-index: 40; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 18px; background: rgba(8,6,3,0.7); }
.veil-mark { width: 56px; height: 56px; border-radius: 50%; border: 2px solid rgba(200,164,93,0.5); box-shadow: 0 0 30px -6px rgba(240,177,75,0.6); animation: veilBreathe 3.2s ease-in-out infinite; }
@keyframes veilBreathe { 0%,100%{ opacity:.6; transform:scale(1) } 50%{ opacity:1; transform:scale(1.06) } }
.veil-dots { display: flex; gap: 6px; }
.veil-dots .d { width: 6px; height: 6px; border-radius: 50%; background: #C8A45D; animation: veilDot 1.1s ease-in-out infinite; }
.veil-dots .d:nth-child(2) { animation-delay: 0.18s; }
.veil-dots .d:nth-child(3) { animation-delay: 0.36s; }
@keyframes veilDot { 0%,100%{ opacity:.25 } 50%{ opacity:1 } }
.veil-line { font-size: 14px; color: rgba(231,214,177,0.8); }
