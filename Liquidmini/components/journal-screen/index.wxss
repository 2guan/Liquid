.jn-scroll { height: 100%; }
.jn { padding: 16px 16px 32px; box-sizing: border-box; }

.jn-head { display: flex; align-items: flex-end; justify-content: space-between; }
.jn-title { display: flex; align-items: baseline; gap: 8px; }
.jn-zh { font-family: var(--font-cinzel); font-size: 26px; letter-spacing: 0.06em; }
.jn-en { font-family: var(--font-cormorant); font-style: italic; font-size: 13px; color: rgba(200,164,93,0.7); }
.jn-count { font-size: 12px; color: rgba(231,214,177,0.45); }
.jn-divider { height: 1px; background: rgba(200,164,93,0.2); margin: 14px 0 18px; }

.jn-empty { display: flex; flex-direction: column; align-items: center; gap: 8px; padding: 64px 0; text-align: center; }
.jn-empty-1 { font-size: 15px; color: rgba(231,214,177,0.55); margin-top: 8px; }
.jn-empty-2 { font-size: 13px; color: rgba(231,214,177,0.35); }
.btn { margin-top: 14px; padding: 11px 28px; border-radius: 999px; background: linear-gradient(180deg, #D89C3A, #A9701F); color: #1A1612; font-size: 14px; }

.jn-list { display: flex; flex-direction: column; gap: 16px; }
.jn-card { position: relative; border-radius: 14px; border: 1px solid rgba(200,164,93,0.2); overflow: hidden; }

.jn-banner { position: relative; height: 128px; overflow: hidden; }
.jn-scene { position: absolute; left: 0; top: 0; width: 100%; height: 100%; }
.jn-scrim-l { position: absolute; left: 0; top: 0; right: 0; bottom: 0; background: linear-gradient(90deg, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.4) 45%, transparent 100%); }
.jn-scrim-r { position: absolute; right: 0; top: 0; bottom: 0; width: 75%; background: linear-gradient(270deg, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.6) 55%, transparent 100%); }
.jn-glass { position: absolute; right: 36px; top: 0; bottom: 0; display: flex; align-items: center; width: 110px; }
.jn-title-wrap { position: absolute; left: 0; top: 0; bottom: 0; max-width: 60%; display: flex; flex-direction: column; justify-content: center; padding-left: 18px; padding-right: 8px; }
.jn-title { font-size: 18px; line-height: 1.25; color: #E7D6B1; text-shadow: 0 2px 8px rgba(0,0,0,0.95); }
.jn-titleen { font-family: var(--font-cormorant); font-style: italic; font-size: 13px; color: rgba(227,198,132,0.9); text-shadow: 0 1px 5px rgba(0,0,0,0.95); margin-top: 2px; }
.jn-mode { width: fit-content; margin-top: 8px; border-radius: 999px; border: 1px solid rgba(200,164,93,0.35); background: rgba(0,0,0,0.4); padding: 2px 10px; font-size: 10px; color: rgba(200,164,93,0.85); }
.jn-hidden { position: absolute; right: 8px; top: 8px; display: flex; align-items: center; gap: 3px; border-radius: 999px; border: 1px solid rgba(200,164,93,0.4); background: rgba(0,0,0,0.55); padding: 2px 8px; font-size: 10px; color: #E3C684; }

.jn-foot { background: rgba(21,17,13,0.85); padding: 12px 16px; }
.jn-poem { font-size: 12px; line-height: 1.6; color: rgba(231,214,177,0.55); }
.jn-date { display: block; font-size: 10px; color: rgba(231,214,177,0.35); margin-top: 8px; }
.jn-del { position: absolute; right: 8px; bottom: 50px; width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; border-radius: 50%; border: 1px solid rgba(200,164,93,0.3); background: rgba(14,11,8,0.8); }
