# keep the build context (and image) small + avoid leaking local secrets
node_modules
.next
out
build
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env / secrets — provided at runtime via docker-compose env_file
.env
.env.*
!.env.example

# vcs / editor / os
.git
.gitignore
.vscode
.idea
.DS_Store

# docs & misc not needed in the image
*.md
design-reference
Dockerfile
docker-compose.yml
.dockerignore
